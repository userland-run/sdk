{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "strict": true,
    "declaration": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["src"],
  // src/terminal.ts is a thin re-export of the sibling terminal package's source
  // (@userland-run/nano-sdk/terminal). That source is typechecked in the terminal
  // repo under its own tsconfig (DOM + @webgpu/types, without the SDK's extra-strict
  // flags like noUncheckedIndexedAccess); re-checking it here under the SDK's config
  // produces false errors. tsup still bundles it via esbuild. So skip it in typecheck.
  "exclude": ["node_modules", "dist", "src/terminal.ts"]
}
