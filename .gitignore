node_modules/
dist/
# The vendored nodert runtime (K9) mirrors upstream cjs-module-lexer, whose
# published tree includes a dist/ dir — re-include it so the byte-identical
# vendor mirror is complete (the global dist/ rule above would hide it).
!src/vendor/nodert/vendor/cjs-module-lexer/dist/
!src/vendor/nodert/vendor/cjs-module-lexer/dist/**
*.tsbuildinfo
*.log
.DS_Store

# Playwright e2e: staged fixtures + harness build + run artifacts (not checked in)
tests/e2e/public/
tests/e2e/dist/
test-results/
playwright-report/
blob-report/
.playwright/
